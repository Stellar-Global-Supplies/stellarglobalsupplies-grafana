          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [
                  8314321
                ],
                "query": "SELECT timestamp, log_group, log_stream, log_level, message FROM Log WHERE forwarder = 'github-actions' SINCE 1 hour ago LIMIT 100"
              }
            ]
          }
        }
      ]
