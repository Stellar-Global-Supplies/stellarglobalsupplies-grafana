      "widgets": [
        {
          "id": "46694507",
          "title": "Lambda \u2014 Invocations (last 24h)",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  8314321
                ],
                "query": "SELECT sum(`aws.lambda.Invocations.Sum`) FROM Metric FACET function_name SINCE 24 hours ago TIMESERIES AUTO"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "46694508",
          "title": "Lambda \u2014 Errors (last 24h)",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  8314321
                ],
                "query": "SELECT sum(`aws.lambda.Errors.Sum`) FROM Metric FACET function_name SINCE 24 hours ago TIMESERIES AUTO"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "46694509",
          "title": "Lambda \u2014 Error Rate %",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
