            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.area"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT count(*) FROM Log WHERE forwarder = 'github-actions' FACET log_group SINCE 24 hours ago TIMESERIES AUTO"
                }
              ]
            }
          },
          {
            "id": "46675066",
            "title": "Total Log Events (24h)",
            "layout": {
              "column": 7,
              "row": 1,
              "width": 3,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT count(*) AS 'Total Events' FROM Log WHERE forwarder = 'github-actions' SINCE 24 hours ago"
                }
              ]
            }
          },
          {
            "id": "46675067",
            "title": "Unique Log Groups Seen",
            "layout": {
              "column": 10,
              "row": 1,
              "width": 3,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT uniqueCount(log_group) AS 'Log Groups' FROM Log WHERE forwarder = 'github-actions' SINCE 24 hours ago"
                }
              ]
            }
          },
          {
            "id": "46675068",
            "title": "Lambda Log Events (24h)",
            "layout": {
              "column": 1,
              "row": 7,
              "width": 6,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.line"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT count(*) FROM Log WHERE forwarder = 'github-actions' AND log_group LIKE '/aws/lambda/%' FACET log_group SINCE 24 hours ago TIMESERIES AUTO"
                }
              ]
            }
          },
          {
            "id": "46675069",
            "title": "Error / Exception Log Lines (message-based fallback)",
            "layout": {
              "column": 7,
              "row": 7,
              "width": 6,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.line"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT count(*) FROM Log WHERE forwarder = 'github-actions' AND (message LIKE '%ERROR%' OR message LIKE '%Exception%' OR message LIKE '%error%') FACET log_group SINCE 24 hours ago TIMESERIES AUTO"
                }
              ]
            }
          },
          {
            "id": "46675070",
            "title": "Recent Log Lines (with log_level)",
            "layout": {
              "column": 1,
              "row": 10,
              "width": 12,
              "height": 5
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.table"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT timestamp, log_group, log_stream, log_level, message FROM Log WHERE forwarder = 'github-actions' SINCE 1 hour ago LIMIT 100"
                }
              ]
            }
          }
        ]
