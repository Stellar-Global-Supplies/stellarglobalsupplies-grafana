        "guid": "ODMxNDMyMXxWSVp8REFTSEJPQVJEfDMyNjQ0Nzc",
        "name": "Logs",
        "description": "CloudWatch logs forwarded from all log groups with log_level filtering",
        "widgets": [
          {
            "id": "46675065",
