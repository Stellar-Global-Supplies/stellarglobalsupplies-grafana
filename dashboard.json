      {
        "guid": "ODMxNDMyMXxWSVp8REFTSEJPQVJEfDMyNjQ0NzQ",
        "name": "Overview",
        "description": "High-level AWS health across all services",
        "widgets": [
          {
            "id": "46675037",
            "title": "Lambda — Invocations (last 24h)",
            "layout": {
              "column": 1,
              "row": 1,
              "width": 4,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.line"
            },
            "rawConfiguration": {
              "legend": {
                "enabled": true
              },
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT sum(value) FROM Metric WHERE metricName = 'aws.lambda.Invocations.Sum' FACET function_name SINCE 24 hours ago TIMESERIES AUTO"
                }
              ],
              "platformOptions": {
                "ignoreTimeRange": false
              }
            }
          },
          {
            "id": "46675038",
            "title": "Lambda — Errors (last 24h)",
            "layout": {
              "column": 5,
              "row": 1,
              "width": 4,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.line"
            },
            "rawConfiguration": {
              "legend": {
                "enabled": true
              },
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT sum(value) FROM Metric WHERE metricName = 'aws.lambda.Errors.Sum' FACET function_name SINCE 24 hours ago TIMESERIES AUTO"
                }
              ],
              "platformOptions": {
                "ignoreTimeRange": false
              }
            }
          },
          {
            "id": "46675039",
            "title": "Lambda — Error Rate %",
            "layout": {
              "column": 9,
              "row": 1,
              "width": 4,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.bar"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT sum(if(metricName = 'aws.lambda.Errors.Sum', value, 0)) / sum(if(metricName = 'aws.lambda.Invocations.Sum', value, 1)) * 100 AS 'Error Rate %' FROM Metric WHERE metricName IN ('aws.lambda.Errors.Sum', 'aws.lambda.Invocations.Sum') FACET function_name SINCE 24 hours ago"
                }
              ]
            }
          },
