{
    "name": "Stellar Global Supplies Cost Dashboard",
    "description": "AWS Cost and Usage Report (CUR) breakdown \u2014 monthly/daily totals, by service, by tag, and granular usage",
    "permissions": "PUBLIC_READ_ONLY",
    "pages": [
      {
        "guid": "ODMxNDMyMXxWSVp8REFTSEJPQVJEfDMyNjYwMDQ",
        "name": "Overview",
        "description": "Monthly and daily cost summary across all AWS services",
        "widgets": [
          {
            "id": "46694566",
            "title": "Total Spend This Month (USD)",
            "layout": {
              "column": 1,
              "row": 1,
              "width": 3,
              "height": 2
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT latest(`aws.cur.v2.summary.monthly_total`) AS 'Total Cost $' FROM Metric WHERE source = 'cur' AND file = 'summary' SINCE 3 days ago"
                }
              ]
            }
          },
          {
            "id": "46694567",
            "title": "Top Service by Cost This Month",
            "layout": {
              "column": 4,
              "row": 1,
              "width": 3,
              "height": 2
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT latest(`aws.cur.v2.summary.service_cost`) AS 'Cost $' FROM Metric WHERE source = 'cur' AND file = 'summary' FACET service_name SINCE 3 days ago LIMIT 1"
                }
              ]
            }
          },
          {
            "id": "46694568",
            "title": "Active Services (non-zero cost)",
            "layout": {
              "column": 7,
              "row": 1,
              "width": 3,
              "height": 2
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT uniqueCount(service_name) AS 'Services' FROM Metric WHERE source = 'cur' AND file = 'summary' SINCE 2 days ago"
                }
              ]
            }
          },
          {
            "id": "46694569",
            "title": "Billing Period",
            "layout": {
              "column": 10,
              "row": 1,
              "width": 3,
              "height": 2
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.billboard"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT latest(billing_period) AS 'Period' FROM Metric WHERE source = 'cur' AND file = 'daily-costs' SINCE 2 days ago"
                }
              ]
            }
          },
          {
            "id": "46694570",
            "title": "Daily Total Cost (USD)",
            "layout": {
              "column": 1,
              "row": 3,
              "width": 8,
              "height": 3
            },
            "linkedEntityGuids": null,
            "visualization": {
              "id": "viz.line"
            },
            "rawConfiguration": {
              "nrqlQueries": [
                {
                  "accountIds": [
                    8314321
                  ],
                  "query": "SELECT sum(`aws.cur.v2.daily.total_cost`) AS 'Daily Cost $' FROM Metric WHERE source = 'cur' AND file = 'daily-costs' SINCE 30 days ago TIMESERIES 1 day"
                }
              ]
            }
          },
