{
  "name": "S3 CloudWatch Metrics",
  "description": "S3 bucket metrics forwarded from CloudWatch to New Relic",
  "permissions": "PUBLIC_READ_ONLY",
  "pages": [
    {
      "name": "S3 Metrics",
      "description": "S3 storage, request, and error metrics",
      "widgets": [
        {
          "title": "Bucket Storage Size",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(custom.cloudwatch.s3.BucketSizeBytes) FROM Metric FACET bucket SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Object Count",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(custom.cloudwatch.s3.NumberOfObjects) FROM Metric FACET bucket SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Request Volume",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.s3.GetObject) + sum(custom.cloudwatch.s3.PutObject) + sum(custom.cloudwatch.s3.ListBucket) FROM Metric FACET bucket SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Error Rate (4xx + 5xx)",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.s3.4xxErrors) + sum(custom.cloudwatch.s3.5xxErrors) AS 'Total Errors (7d)' FROM Metric SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Errors by Bucket",
          "layout": {
            "column": 11,
            "row": 4,
            "width": 2,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.s3.4xxErrors) AS '4xx', sum(custom.cloudwatch.s3.5xxErrors) AS '5xx' FROM Metric FACET bucket SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Requests by Type (Last 7d)",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.s3.GetObject) AS 'GetObject', sum(custom.cloudwatch.s3.PutObject) AS 'PutObject', sum(custom.cloudwatch.s3.ListBucket) AS 'ListBucket', sum(custom.cloudwatch.s3.DeleteObject) AS 'DeleteObject', sum(custom.cloudwatch.s3.HeadObject) AS 'HeadObject' FROM Metric SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        }
      ]
    }
  ]
}