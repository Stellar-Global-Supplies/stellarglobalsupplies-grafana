{
  "name": "DynamoDB CloudWatch Metrics",
  "description": "DynamoDB table metrics forwarded from CloudWatch to New Relic",
  "permissions": "PUBLIC_READ_ONLY",
  "pages": [
    {
      "name": "DynamoDB Metrics",
      "description": "DynamoDB capacity, throttling, latency, and error metrics",
      "widgets": [
        {
          "title": "Read/Write Capacity (Consumed)",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(custom.cloudwatch.dynamodb.ConsumedReadCapacityUnits) AS 'Read (CU)', average(custom.cloudwatch.dynamodb.ConsumedWriteCapacityUnits) AS 'Write (CU)' FROM Metric FACET table SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Provisioned vs Consumed Capacity",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(custom.cloudwatch.dynamodb.ConsumedReadCapacityUnits) AS 'Consumed Read', average(custom.cloudwatch.dynamodb.ProvisionedReadCapacityUnits) AS 'Provisioned Read' FROM Metric SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Throttled Requests",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.dynamodb.ThrottledRequests) FROM Metric FACET table SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Throttle Events",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.dynamodb.ReadThrottleEvents) AS 'Read Throttles', sum(custom.cloudwatch.dynamodb.WriteThrottleEvents) AS 'Write Throttles' FROM Metric FACET table SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "System & User Errors",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.dynamodb.SystemErrors) AS 'System Errors', sum(custom.cloudwatch.dynamodb.UserErrors) AS 'User Errors' FROM Metric SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Successful Request Latency",
          "layout": {
            "column": 7,
            "row": 7,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(custom.cloudwatch.dynamodb.SuccessfulRequestLatency) FROM Metric FACET table SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Returned Item Count",
          "layout": {
            "column": 1,
            "row": 10,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.dynamodb.ReturnedItemCount) FROM Metric FACET table SINCE 7 days ago TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Throttling Alert Status",
          "layout": {
            "column": 7,
            "row": 10,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(custom.cloudwatch.dynamodb.ThrottledRequests) AS 'Total Throttled Requests (7d)' FROM Metric SINCE 7 days ago"
              }
            ]
          }
        }
      ]
    }
  ]
}